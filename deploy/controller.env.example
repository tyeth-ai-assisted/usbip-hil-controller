# /etc/hil/controller.env — copy and fill in real values, mode 0640, owner hil.
# Loaded by the systemd unit via EnvironmentFile=.

HIL_DB_PATH=/var/lib/hil/jobs.db
HIL_TOPOLOGY_FILE=/etc/hil/topology.yaml
HIL_HOST=127.0.0.1
HIL_PORT=8080

# Bootstrap token: set this to a random string for initial setup,
# then replace with proper DB tokens via scripts/mint-token.py.
HIL_STATIC_TOKEN=

# Bench credentials — loaded into secret profiles at runtime.
HIL_BENCH_AIO_USERNAME=
HIL_BENCH_AIO_KEY=
HIL_BENCH_WIFI_SSID=
HIL_BENCH_WIFI_PASSWORD=
