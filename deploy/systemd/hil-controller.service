[Unit]
Description=HIL Controller — hardware-in-the-loop test broker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hil
Group=hil
WorkingDirectory=/opt/hil-controller
ExecStart=/opt/hil-controller/.venv/bin/hil-controller
Restart=on-failure
RestartSec=5s

# Config via environment
EnvironmentFile=/etc/hil/controller.env

# Minimal filesystem isolation
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/hil

[Install]
WantedBy=multi-user.target
