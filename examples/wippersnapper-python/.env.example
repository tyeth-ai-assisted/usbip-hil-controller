# Drop-in .env for pytest runs against the Python Wippersnapper variant.
# Loaded by pytest via python-dotenv. The HIL controller substitutes
# these from per-repo secrets at run time; commit only this example,
# never a populated .env.

HIL_IO_USERNAME=
HIL_IO_KEY=

HIL_WIFI_SSID=
HIL_WIFI_PASSWORD=

# Bench defaults from vendor/hil-detection/references/hardware.md.
# Override per-bench if multiple controllers exist.
HIL_PROTOMQ_HOST=192.168.1.210
HIL_PROTOMQ_PORT=1884
